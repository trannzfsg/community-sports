rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? currentUserDoc().data.role
        : null;
    }

    function isAdmin() {
      return isSignedIn() && currentUserRole() == 'admin';
    }

    function isOrganiser() {
      return isSignedIn() && currentUserRole() == 'organiser';
    }

    function isPlayer() {
      return isSignedIn() && currentUserRole() == 'player';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function signedInEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : null;
    }

    function hasManagedUserForSignedInEmail() {
      return signedInEmail() != null
        && exists(/databases/$(database)/documents/managedUsers/$(signedInEmail()));
    }

    function managedUserForSignedInEmail() {
      return get(/databases/$(database)/documents/managedUsers/$(signedInEmail()));
    }

    function allowedSelfRegistrationRole() {
      return hasManagedUserForSignedInEmail()
        ? managedUserForSignedInEmail().data.role
        : 'player';
    }

    function allowedSelfRegistrationStatus() {
      return hasManagedUserForSignedInEmail()
        ? managedUserForSignedInEmail().data.status
        : 'active';
    }

    function seriesOwnedByCurrentOrganiser() {
      return isSignedIn() && resource.data.organiserId == request.auth.uid;
    }

    function newSeriesOwnedByCurrentOrganiser() {
      return isSignedIn() && request.resource.data.organiserId == request.auth.uid;
    }

    function eventOwnedByCurrentOrganiser() {
      return isSignedIn() && resource.data.organiserId == request.auth.uid;
    }

    function eventBelongsToCurrentOrganiserBySeries() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/sessions/$(resource.data.sessionSeriesId))
        && get(/databases/$(database)/documents/sessions/$(resource.data.sessionSeriesId)).data.organiserId == request.auth.uid;
    }

    function newEventOwnedByCurrentOrganiser() {
      return isSignedIn() && request.resource.data.organiserId == request.auth.uid;
    }

    function validSport(value) {
      return value in ['Badminton', 'Basketball'];
    }

    function validDayOfWeek(value) {
      return value in ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
    }

    function registrationOwnedByCurrentUser() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function registrationForOrganiserEvent() {
      return isOrganiser()
        && exists(/databases/$(database)/documents/sessionEvents/$(resource.data.sessionEventId))
        && get(/databases/$(database)/documents/sessionEvents/$(resource.data.sessionEventId)).data.organiserId == request.auth.uid;
    }

    function newRegistrationForOrganiserEvent() {
      return isOrganiser()
        && exists(/databases/$(database)/documents/sessionEvents/$(request.resource.data.sessionEventId))
        && get(/databases/$(database)/documents/sessionEvents/$(request.resource.data.sessionEventId)).data.organiserId == request.auth.uid;
    }

    function paymentHasOwnedRegistration() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/registrations/$(resource.data.registrationId))
        && get(/databases/$(database)/documents/registrations/$(resource.data.registrationId)).data.userId == request.auth.uid;
    }

    function newPaymentHasOwnedRegistration() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/registrations/$(request.resource.data.registrationId))
        && get(/databases/$(database)/documents/registrations/$(request.resource.data.registrationId)).data.userId == request.auth.uid;
    }

    function paymentBelongsToOrganiserByRegistration() {
      return isOrganiser()
        && exists(/databases/$(database)/documents/registrations/$(resource.data.registrationId))
        && exists(/databases/$(database)/documents/sessionEvents/$(get(/databases/$(database)/documents/registrations/$(resource.data.registrationId)).data.sessionEventId))
        && get(/databases/$(database)/documents/sessionEvents/$(get(/databases/$(database)/documents/registrations/$(resource.data.registrationId)).data.sessionEventId)).data.organiserId == request.auth.uid;
    }

    function newPaymentBelongsToOrganiserByRegistration() {
      return isOrganiser()
        && exists(/databases/$(database)/documents/registrations/$(request.resource.data.registrationId))
        && exists(/databases/$(database)/documents/sessionEvents/$(get(/databases/$(database)/documents/registrations/$(request.resource.data.registrationId)).data.sessionEventId))
        && get(/databases/$(database)/documents/sessionEvents/$(get(/databases/$(database)/documents/registrations/$(request.resource.data.registrationId)).data.sessionEventId)).data.organiserId == request.auth.uid;
    }

    function managedUserBelongsToSignedInEmail() {
      return isSignedIn()
        && resource.data.email is string
        && signedInEmail() != null
        && lower(resource.data.email) == lower(signedInEmail());
    }

    function managedUserSelfLinkUpdate() {
      return managedUserBelongsToSignedInEmail()
        && (resource.data.userId == null || resource.data.userId == request.auth.uid)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status;
    }

    match /managedUsers/{managedUserId} {
      allow read: if isAdmin() || managedUserBelongsToSignedInEmail();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || managedUserSelfLinkUpdate();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == allowedSelfRegistrationRole()
        && request.resource.data.status == allowedSelfRegistrationStatus();
      allow update: if (isOwner(userId)
        && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /players/{playerId} {
      allow read: if isAdmin()
        || isPlayer()
        || (isOrganiser() && (resource.data.ownerOrganiserId == request.auth.uid || resource.data.ownerOrganiserId == null));
      allow create: if isAdmin()
        || (isOrganiser() && request.resource.data.ownerOrganiserId == request.auth.uid)
        || (isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.ownerOrganiserId == null);
      allow update: if isAdmin()
        || (isOrganiser() && resource.data.ownerOrganiserId == request.auth.uid)
        || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.ownerOrganiserId == null);
      allow delete: if isAdmin() || (isOrganiser() && resource.data.ownerOrganiserId == request.auth.uid);
    }

    match /sessions/{sessionId} {
      allow read: if isAdmin()
        || isPlayer()
        || (isOrganiser() && seriesOwnedByCurrentOrganiser());
      allow create: if (isAdmin() || (isOrganiser() && newSeriesOwnedByCurrentOrganiser()))
        && validSport(request.resource.data.typeOfSport)
        && validDayOfWeek(request.resource.data.dayOfWeek);
      allow update, delete: if (isAdmin() || (isOrganiser() && seriesOwnedByCurrentOrganiser()))
        && validSport(request.resource.data.typeOfSport)
        && validDayOfWeek(request.resource.data.dayOfWeek);
    }

    match /sessionEvents/{eventId} {
      allow read: if isAdmin()
        || isPlayer()
        || (isOrganiser() && (eventOwnedByCurrentOrganiser() || eventBelongsToCurrentOrganiserBySeries()));
      allow create, update, delete: if isAdmin()
        || (isOrganiser() && newEventOwnedByCurrentOrganiser());
    }

    match /registrations/{registrationId} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        || newRegistrationForOrganiserEvent()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin()
        || registrationForOrganiserEvent()
        || (registrationOwnedByCurrentUser()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.sessionEventId == resource.data.sessionEventId
          && request.resource.data.sessionSeriesId == resource.data.sessionSeriesId
          && request.resource.data.playerName == resource.data.playerName
          && request.resource.data.playerEmail == resource.data.playerEmail
          && request.resource.data.organiserPaid == resource.data.organiserPaid);
      allow delete: if isAdmin() || registrationForOrganiserEvent() || registrationOwnedByCurrentUser();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin()
        || (isOrganiser() && (resource.data.organiserId == request.auth.uid || paymentBelongsToOrganiserByRegistration()))
        || (isSignedIn() && (resource.data.userId == request.auth.uid || paymentHasOwnedRegistration()));
      allow create: if isAdmin()
        || (isOrganiser() && (request.resource.data.organiserId == request.auth.uid || newPaymentBelongsToOrganiserByRegistration()))
        || (isSignedIn() && (request.resource.data.userId == request.auth.uid || newPaymentHasOwnedRegistration()));
      allow update: if isAdmin()
        || (isOrganiser()
          && (resource.data.organiserId == request.auth.uid || paymentBelongsToOrganiserByRegistration())
          && (request.resource.data.organiserId == request.auth.uid || newPaymentBelongsToOrganiserByRegistration()))
        || (isSignedIn()
          && (resource.data.userId == request.auth.uid || paymentHasOwnedRegistration())
          && (request.resource.data.userId == request.auth.uid || newPaymentHasOwnedRegistration()));
      allow delete: if isAdmin()
        || (isOrganiser() && (resource.data.organiserId == request.auth.uid || paymentBelongsToOrganiserByRegistration()))
        || (isSignedIn() && (resource.data.userId == request.auth.uid || paymentHasOwnedRegistration()));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
