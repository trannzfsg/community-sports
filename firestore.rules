rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? currentUserDoc().data.role
        : null;
    }

    function signedInEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function derivedRoleFromEmail() {
      return signedInEmail() == "tranzha83@gmail.com"
        ? "admin"
        : signedInEmail() == "tranzha83+badmintonmonday@gmail.com"
          ? "organiser"
          : "player";
    }

    function isAdmin() {
      return isSignedIn() && currentUserRole() == 'admin';
    }

    function isOrganiser() {
      return isSignedIn() && currentUserRole() == 'organiser';
    }

    function isPlayer() {
      return isSignedIn() && currentUserRole() == 'player';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function sessionOwnedByCurrentOrganiser() {
      return isSignedIn() && resource.data.organiserId == request.auth.uid;
    }

    function newSessionOwnedByCurrentOrganiser() {
      return isSignedIn() && request.resource.data.organiserId == request.auth.uid;
    }

    function validSport(value) {
      return value in ['Badminton', 'Basketball'];
    }

    function validDayOfWeek(value) {
      return value in ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
    }

    function registrationOwnedByCurrentUser() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function newRegistrationOwnedByCurrentUser() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function registrationForOrganiserSession() {
      return isOrganiser()
        && exists(/databases/$(database)/documents/sessions/$(resource.data.sessionId))
        && get(/databases/$(database)/documents/sessions/$(resource.data.sessionId)).data.organiserId == request.auth.uid;
    }

    function newRegistrationForOrganiserSession() {
      return isOrganiser()
        && exists(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId))
        && get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.organiserId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == derivedRoleFromEmail();
      allow update: if (isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email) || isAdmin();
      allow delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isAdmin()
        || isPlayer()
        || (isOrganiser() && sessionOwnedByCurrentOrganiser());
      allow create: if (isAdmin() || (isOrganiser() && newSessionOwnedByCurrentOrganiser()))
        && validSport(request.resource.data.typeOfSport)
        && validDayOfWeek(request.resource.data.dayOfWeek);
      allow update, delete: if (isAdmin() || (isOrganiser() && sessionOwnedByCurrentOrganiser()))
        && validSport(request.resource.data.typeOfSport)
        && validDayOfWeek(request.resource.data.dayOfWeek);
    }

    match /registrations/{registrationId} {
      allow read: if isAdmin()
        || registrationOwnedByCurrentUser()
        || registrationForOrganiserSession();
      allow create: if isAdmin()
        || newRegistrationOwnedByCurrentUser()
        || newRegistrationForOrganiserSession();
      allow update: if isAdmin()
        || registrationForOrganiserSession()
        || (registrationOwnedByCurrentUser()
          && request.resource.data.playerPaid == request.resource.data.playerPaid
          && request.resource.data.organiserPaid == resource.data.organiserPaid);
      allow delete: if isAdmin() || registrationForOrganiserSession();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin()
        || (isOrganiser() && resource.data.organiserId == request.auth.uid)
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isOrganiser() && resource.data.organiserId == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
